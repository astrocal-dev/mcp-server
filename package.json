{
  "name": "@astrocal/mcp-server",
  "version": "0.1.2",
  "type": "module",
  "description": "MCP server for Astrocal scheduling API — manage bookings from AI agents via the Model Context Protocol",
  "author": "Astrocal",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/astrocal-dev/mcp-server"
  },
  "homepage": "https://astrocal.dev",
  "bugs": {
    "url": "https://github.com/astrocal-dev/mcp-server/issues"
  },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "astrocal-mcp": "dist/index.js"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsx watch src/index.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src/",
    "prepublishOnly": "pnpm build"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "posthog-node": "^5.35.6",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^25.9.1",
    "tsup": "^8.5.1",
    "tsx": "^4.22.3",
    "typescript": "^5.9.3",
    "vitest": "^4.1.7"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "scheduling",
    "calendar",
    "ai-agents",
    "booking",
    "astrocal",
    "claude",
    "claude-desktop"
  ]
}
